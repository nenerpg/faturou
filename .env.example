# Servidor
PORT=3000

# Supabase (banco de dados PostgreSQL)
# Settings → API → Project URL e Service Role Key
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...

# Produção: bloquear geração de números sem PIX
ALLOW_PUBLIC_PARTICIPAR=false

# Login do painel admin (opcional — há padrão no código)
ADMIN_EMAIL=fenix@sortereal.com.br
ADMIN_PASSWORD=258456
# ADMIN_TOKEN=  # opcional: token fixo; se vazio, é derivado do e-mail+senha

# URLs públicas (Vercel)
PUBLIC_API_URL=https://www.sortereal.org
PUBLIC_SITE_URL=https://www.sortereal.org

# Cash API (Animus Pay) — PIX e confirmação de pagamento (OBRIGATÓRIO em produção)
# Token: painel Animus → API → Gerar/copiar chave
CASH_API_TOKEN=
CASH_API_BASE_URL=https://api.animuspay.com.br/api/public/cash
# Webhook Cash-In (POST JSON) — configure também no checkout Animus
CASH_POSTBACK_URL=https://www.sortereal.org/api/webhooks/cash
# Pagamento: omita ou deixe vazio = PIX via Cash API (recomendado, confirma automático)
# PAYMENT_MODE=hosted  # NÃO use em produção — checkout go.animuspay.com.br não vincula ao sistema
# Opcional: URL única de fallback. Cada pacote pode ter checkoutUrl próprio no admin.
ANIMUS_CHECKOUT_BASE_URL=

# E-mail (Resend) — números após pagamento
RESEND_API_KEY=
EMAIL_FROM=Sorte Real <noreply@sortereal.org>

# Link do ebook no e-mail (opcional se o checkout já entrega)
# Ebook no e-mail (padrão: PUBLIC_SITE_URL/ebook.pdf — arquivo em site/ebook.pdf)
# EBOOK_URL=https://seudominio.com/ebook.pdf
# EBOOK_TITULO=O Legado de Steve Jobs
